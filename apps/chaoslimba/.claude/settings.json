{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit-check.sh",
            "timeout": 120,
            "statusMessage": "Running type check, lint, and build..."
          }
        ]
      }
    ]
  }
}
